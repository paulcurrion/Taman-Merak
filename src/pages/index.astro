---
import Layout from '../layouts/Layout.astro';
import WayangDivider from '../components/WayangDivider.astro';

export const prerender = true;

const tracks = [
    { title: 'Tamban Manyar Sewu rehearsal', desc: 'Javanese classical', duration: '5:42', file: 'audio/Tamban-Manyar-Sewu-rehearsal.mp3' },
];
---

<Layout title="Taman Merak — Gamelan Ensemble Belgrade">
    <!-- Hero -->
    <section class="flex flex-col items-center justify-center min-h-[85vh] px-6 text-center">
        <WayangDivider class="mb-10 w-16 sm:w-20 text-gold" />

        <h1 class="mb-5">Taman Merak</h1>

        <p class="text-gold-dim tracking-[0.25em] uppercase text-xs sm:text-sm mb-8 font-medium">
            Gamelan Ensemble Belgrade
        </p>

        <p class="max-w-sm text-cream-muted leading-relaxed text-sm sm:text-base">
            Bringing traditional and experimental gamelan music to the Balkans.
        </p>

        <nav class="mt-12 flex gap-8 text-[0.65rem] tracking-[0.25em] uppercase">
            <a href="#gallery" class="text-gold-dim hover:text-gold transition-colors">Gallery</a>
            <a href="#listen" class="text-gold-dim hover:text-gold transition-colors">Listen</a>
        </nav>
    </section>

    <WayangDivider class="mb-10 w-32 sm:w-48 mx-auto text-gold" />

    <!-- Gallery -->
    <section class="px-6 py-16 sm:py-24 max-w-4xl mx-auto w-full" id="gallery">
        <div class="text-center mb-10">
            <h2>Gallery</h2>
            <div class="mt-3 mx-auto w-12 h-px bg-gold/20"></div>
        </div>

        <div class="gallery-item">
            <img src="/images/choice-1.jpg" alt="Description of first photo">
        </div>
        <div class="gallery-item">
            <img src="/images/choice-2.jpg" alt="Description of second photo">
        </div>
        <div class="gallery-item">
            <img src="/images/choice-3.jpg" alt="Description of third photo">
        </div>
        <div class="gallery-item">
            <img src="/images/choice-4.jpg" alt="Description of fourth photo">
        </div>
        <div class="gallery-item">
            <img src="/images/choice-5.jpg" alt="Description of fifth photo">
        </div>
        <div class="gallery-item">
            <img src="/images/choice-6.jpg" alt="Description of sixth photo">
        </div>

        <div class="text-center mt-8">
            <a
                href="https://www.instagram.com/ensemble_taman_merak/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-xs tracking-[0.2em] uppercase text-gold-dim hover:text-gold transition-colors"
            >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" /><circle cx="12" cy="12" r="5" /><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" /></svg>
                Follow on Instagram &rarr;
            </a>
        </div>
    </section>

   <WayangDivider class="mb-10 w-32 sm:w-48 mx-auto text-gold" />

    <!-- Music -->
    <section class="px-6 py-16 sm:py-24 max-w-2xl mx-auto w-full" id="listen">
        <div class="text-center mb-10">
            <h2>Listen</h2>
            <div class="mt-3 mx-auto w-12 h-px bg-gold/20"></div>
        </div>

        <div class="flex flex-col gap-3">
            {
                tracks.map((track) => (
                    <div class="track-card" data-src={track.file}>
                        <button class="play-btn" aria-label={`Play ${track.title}`}>
                            <svg
                                class="play-icon ml-0.5"
                                width="12"
                                height="14"
                                viewBox="0 0 12 14"
                                fill="currentColor"
                            >
                                <polygon points="1,0 12,7 1,14" />
                            </svg>
                            <svg
                                class="pause-icon ml-0.5 hidden"
                                width="10"
                                height="14"
                                viewBox="0 0 10 14"
                                fill="currentColor"
                            >
                                <rect x="0" y="0" width="3" height="14" />
                                <rect x="7" y="0" width="3" height="14" />
                            </svg>
                        </button>
                        <div class="flex-1 min-w-0">
                            <p class="text-gold-light text-sm font-medium">{track.title}</p>
                            <p class="text-cream-muted text-xs mt-0.5">{track.desc}</p>
                        </div>
                        <span class="track-duration text-cream-muted text-xs tabular-nums">{track.duration}</span>
                    </div>
                ))
            }
        </div>
    </section>

    <script>
        const cards = document.querySelectorAll('.track-card[data-src]');
        let currentAudio: HTMLAudioElement | null = null;
        let currentCard: Element | null = null;

        cards.forEach((card) => {
            const btn = card.querySelector('.play-btn') as HTMLButtonElement;
            btn.addEventListener('click', () => {
                const src = card.getAttribute('data-src')!;

                // If clicking the currently playing track, toggle pause/play
                if (currentCard === card && currentAudio) {
                    if (currentAudio.paused) {
                        currentAudio.play();
                        setPlaying(card, true);
                    } else {
                        currentAudio.pause();
                        setPlaying(card, false);
                    }
                    return;
                }

                // Stop any currently playing track
                if (currentAudio) {
                    currentAudio.pause();
                    currentAudio.currentTime = 0;
                    if (currentCard) setPlaying(currentCard, false);
                }

                // Play new track
                currentAudio = new Audio(src);
                currentCard = card;
                currentAudio.play().catch(() => {
                    // File not found or not loadable
                    setPlaying(card, false);
                });
                setPlaying(card, true);

                currentAudio.addEventListener('ended', () => {
                    setPlaying(card, false);
                    currentAudio = null;
                    currentCard = null;
                });
            });
        });

        function setPlaying(card: Element, playing: boolean) {
            const playIcon = card.querySelector('.play-icon') as SVGElement;
            const pauseIcon = card.querySelector('.pause-icon') as SVGElement;
            if (playing) {
                playIcon.classList.add('hidden');
                pauseIcon.classList.remove('hidden');
            } else {
                playIcon.classList.remove('hidden');
                pauseIcon.classList.add('hidden');
            }
        }
    </script>

    <!-- Footer -->
    <footer class="px-6 pt-16 pb-12 sm:pt-24 sm:pb-16 text-center">
        <WayangDivider class="mb-10 w-16 sm:w-20 text-gold" />
        <p class="text-cream-muted text-xs tracking-[0.2em]">Taman Merak&ensp;&middot;&ensp;Belgrade, Serbia</p>
    </footer>
</Layout>
