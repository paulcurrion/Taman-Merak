---
interface Props {
    class?: string;
}

const { class: className } = Astro.props;
---

<div class={className}>
    <svg viewBox="0 0 100 150" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
        <!-- Gunungan / Kayon — the tree-of-life motif from wayang kulit -->

        <!-- Outer leaf shape -->
        <path
            d="M50,5 C53,15 75,40 75,75 C75,100 64,118 50,118 C36,118 25,100 25,75 C25,40 47,15 50,5Z"
            stroke="currentColor"
            stroke-width="0.8"
        />

        <!-- Inner boundary -->
        <path
            d="M50,22 C52,28 65,46 65,70 C65,88 58,100 50,100 C42,100 35,88 35,70 C35,46 48,28 50,22Z"
            stroke="currentColor"
            stroke-width="0.5"
            opacity="0.4"
        />

        <!-- Central tree stem -->
        <line x1="50" y1="30" x2="50" y2="95" stroke="currentColor" stroke-width="0.4" opacity="0.3" />

        <!-- Upper branches -->
        <path d="M50,42 C56,46 60,52 56,56" stroke="currentColor" stroke-width="0.4" fill="none" opacity="0.25" />
        <path d="M50,42 C44,46 40,52 44,56" stroke="currentColor" stroke-width="0.4" fill="none" opacity="0.25" />

        <!-- Middle branches -->
        <path d="M50,58 C55,61 58,66 55,69" stroke="currentColor" stroke-width="0.4" fill="none" opacity="0.25" />
        <path d="M50,58 C45,61 42,66 45,69" stroke="currentColor" stroke-width="0.4" fill="none" opacity="0.25" />

        <!-- Lower branches -->
        <path d="M50,74 C54,77 56,81 54,83" stroke="currentColor" stroke-width="0.4" fill="none" opacity="0.25" />
        <path d="M50,74 C46,77 44,81 46,83" stroke="currentColor" stroke-width="0.4" fill="none" opacity="0.25" />

        <!-- Central jewel -->
        <circle cx="50" cy="50" r="2" fill="currentColor" opacity="0.2" />

        <!-- Top finial -->
        <circle cx="50" cy="10" r="1.2" fill="currentColor" opacity="0.3" />

        <!-- Base stand -->
        <path
            d="M43,118 L43,130 L57,130 L57,118"
            stroke="currentColor"
            stroke-width="0.6"
            fill="none"
            opacity="0.35"
        />
        <line x1="45" y1="124" x2="55" y2="124" stroke="currentColor" stroke-width="0.3" opacity="0.2" />
    </svg>
</div>
